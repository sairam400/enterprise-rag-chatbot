# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your ANTHROPIC_API_KEY.
# Everything else has a working default (free local embeddings + ChromaDB).
#   cp .env.example .env
# ---------------------------------------------------------------------------

# === REQUIRED ===============================================================
ANTHROPIC_API_KEY=sk-ant-...

# === LLM ====================================================================
# Provider: anthropic | azure_openai
LLM_PROVIDER=anthropic
# Default is current-generation Opus. For cheaper demos use claude-sonnet-5.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=2048

# === EMBEDDINGS =============================================================
# Provider: sentence_transformers (local, free) | azure_openai
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === VECTOR STORE ===========================================================
# Provider: chroma (local, free) | azure_search
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=documents

# === CHUNKING ===============================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# === RETRIEVAL ==============================================================
TOP_K=5

# === APP ====================================================================
MAX_UPLOAD_MB=25
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === AZURE OPENAI (optional — only if LLM_PROVIDER/EMBEDDING_PROVIDER=azure_openai) ===
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# === AZURE AI SEARCH (optional — only if VECTOR_STORE=azure_search) =========
# AZURE_SEARCH_ENDPOINT=https://<service>.search.windows.net
# AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX=documents
